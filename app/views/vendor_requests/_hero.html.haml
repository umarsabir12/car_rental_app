- field_class = 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2'

%section.hero-section.text-white.mt-16.py-8.md:py-16.px-4.sm:px-6.lg:px-8
  .max-w-7xl.mx-auto
    .grid.grid-cols-1.lg:grid-cols-2.gap-8.lg:gap-12.items-center.hero-content
      / Left Content
      %div
        %h1.text-3xl.sm:text-4xl.lg:text-6xl.font-bold.leading-tight.mb-4.md:mb-6.text-white
          Transform your cars into steady daily revenue
        %p.text-lg.sm:text-xl.text-blue-50.mb-4.md:mb-8.leading-relaxed.font-bold
          List your fleet today and start getting confirmed bookings.
        %p.text-base.sm:text-lg.text-blue-100.mb-6.md:mb-8.leading-relaxed
          Accelerate the growth of your car rental business with WheelsOnRent. Keep your cars on the road, not in the lot. Join the UAE's leading rental marketplace and earn daily.
        %div.flex.gap-4
          = link_to 'Learn More', '#why-partner', class: 'inline-block px-6 sm:px-8 py-3 sm:py-4 border-2 border-white text-white rounded-lg font-bold text-base sm:text-lg hover:bg-white hover:text-[#3A6363]'

      / Right - Form
      .bg-white.rounded-xl.shadow-2xl.p-6.sm:p-8.mt-8.lg:mt-0
        %h3.text-xl.sm:text-2xl.font-bold.text-gray-900.mb-4.sm:mb-6
          Get Started Today

        = form_with model: @vendor_request, url: vendor_requests_path, method: :post, class: 'space-y-4', data: { show_loader: true } do |f|
          = render 'shared/form_errors', object: @vendor_request
          .grid.grid-cols-1.sm:grid-cols-2.gap-4
            %div
              = f.label :first_name, 'First Name', class: 'block text-sm font-semibold text-gray-700 mb-2'
              = f.text_field :first_name,
                placeholder: 'John',
                class: field_class,
                autocomplete: 'given-name',
                spellcheck: 'false',
                required: true
            %div
              = f.label :last_name, 'Last Name', class: 'block text-sm font-semibold text-gray-700 mb-2'
              = f.text_field :last_name,
                placeholder: 'Doe',
                class: field_class,
                autocomplete: 'family-name',
                spellcheck: 'false',
                required: true

          %div
            = f.label :company_name, 'Company Name', class: 'block text-sm font-semibold text-gray-700 mb-2'
            = f.text_field :company_name,
              placeholder: 'Your Company',
              class: field_class,
              autocomplete: 'company_name',
              required: true

          %div
            = f.label :email, 'Email Address', class: 'block text-sm font-semibold text-gray-700 mb-2'
            = f.email_field :email,
              placeholder: 'john@example.com',
              class: field_class,
              autocomplete: 'email',
              required: true

          .grid.grid-cols-1.sm:grid-cols-2.gap-4
            %div
              = f.label :phone, 'Phone Number', class: 'block text-sm font-semibold text-gray-700 mb-2'
              = f.telephone_field :phone,
                placeholder: '+971 50 123 4567',
                class: field_class,
                autocomplete: 'tel',
                required: true

            %div
              = f.label :vehicle_count, 'Number of Vehicles', class: 'block text-sm font-semibold text-gray-700 mb-2'
              = f.number_field :vehicle_count,
                placeholder: 'Enter number of vehicles',
                class: field_class,
                min: 1,
                required: true

          = f.submit 'Submit Request', class: 'w-full px-6 py-3 text-white rounded-lg font-bold text-lg shadow-lg', style: 'background-color: #00B4D8'

          %p.text-xs.text-gray-500.text-center.mt-4
            We respect your privacy. Your information will never be shared.