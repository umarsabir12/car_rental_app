.container.mx-auto.px-4.py-8.mt-10
  .max-w-md.mx-auto
    / Header
    .text-center.mb-8
      %i{class: 'fas fa-lock text-4xl mb-4', style: 'color: #3a6363'}
      %h1.text-3xl.font-bold.text-gray-900 Forgot Password
      %p.text-gray-600.mt-2 Enter your email address to receive vendor password reset instructions.

    / Flash Messages
    - if flash[:notice]
      .mb-6.p-4.rounded-lg.border{style: 'background-color: #f0f9f0; border-color: #3a6363; color: #166534'}
        .flex.items-center
          %i.fas.fa-check-circle.mr-2{style: 'color: #3a6363'}
          %span= flash[:notice]
    - if flash[:alert]
      .mb-6.p-4.bg-red-50.border.border-red-200.rounded-lg.text-red-800
        .flex.items-center
          %i.fas.fa-exclamation-circle.text-red-600.mr-2
          %span= flash[:alert]

    / Password Reset Form
    .bg-white.rounded-xl.shadow-lg.p-8.overflow-hidden
      = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, id: 'password-reset-form' }) do |f|
        .space-y-6
          .field.space-y-2
            = f.label :email, class: 'block text-sm font-medium text-gray-700'
            = f.email_field :email, 
                autocomplete: 'email',
                class: 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none transition duration-200',
                style: 'focus:ring-2 focus:ring-opacity-50',
                placeholder: 'Enter your email address',
                id: 'reset-email',
                onfocus: "this.style.borderColor='#3a6363'; this.style.boxShadow='0 0 0 3px rgba(58, 99, 99, 0.1)'",
                onblur: "this.style.borderColor='#d1d5db'; this.style.boxShadow='none'"
            - if resource.errors[:email].any?
              %p.text-red-600.text-sm.mt-1= resource.errors[:email].join(', ')

          .field
            = f.submit 'Send Reset Instructions', 
                class: 'w-full text-white font-medium py-3 px-4 rounded-lg transition duration-200 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-opacity-50',
                style: 'background-color: #3a6363; hover:background-color: #2d4f4f',
                id: 'reset-submit'

      / Additional Links
      .mt-8.text-center.space-y-4
        = link_to 'Back to Sign In', new_session_path(resource_name), 
            class: 'font-medium transition-colors hover:underline block',
            style: 'color: #3a6363'
        %p.text-gray-500.text-sm
          Don't have an account? 
          = link_to 'Sign up here', new_registration_path(resource_name), 
              class: 'font-medium transition-colors hover:underline',
              style: 'color: #3a6363'

    / Help Section
    .mt-8.rounded-xl.p-6{style: 'background-color: #f0f9f9'}
      %h3.text-lg.font-semibold.mb-3.flex.items-center{style: 'color: #2d4f4f'}
        %i.fas.fa-info-circle.mr-2
        Need Help?
      %p.text-sm.mb-3{style: 'color: #3a6363'}
        If you're having trouble accessing your vendor account, we can help you reset your password.
      %ul.text-sm.space-y-2{style: 'color: #3a6363'}
        %li.flex.items-start
          %i.fas.fa-check.mr-2.mt-0.5{style: 'color: #3a6363'}
          Enter the email address associated with your vendor account
        %li.flex.items-start
          %i.fas.fa-check.mr-2.mt-0.5{style: 'color: #3a6363'}
          Check your email for password reset instructions
        %li.flex.items-start
          %i.fas.fa-check.mr-2.mt-0.5{style: 'color: #3a6363'}
          Follow the link to create a new password

:javascript
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('password-reset-form');
    if (!form) return;
    const emailField = document.getElementById('reset-email');
    const submitButton = document.getElementById('reset-submit');
    
    // Email validation
    function validateEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }
    
    // Real-time email validation
    emailField.addEventListener('blur', function() {
      const email = this.value.trim();
      clearFieldError(this);
      
      if (email && !validateEmail(email)) {
        showFieldError(this, 'Please enter a valid email address');
      }
    });
    
    emailField.addEventListener('input', function() {
      clearFieldError(this);
    });
    
    // Form submission enhancement
    form.addEventListener('submit', function(e) {
      const email = emailField.value.trim();
      
      if (!email) {
        e.preventDefault();
        showFieldError(emailField, 'Email address is required');
        return;
      }
      
      if (!validateEmail(email)) {
        e.preventDefault();
        showFieldError(emailField, 'Please enter a valid email address');
        return;
      }
      
      // Show loading state
      submitButton.disabled = true;
      submitButton.value = 'Sending...';
      submitButton.classList.add('opacity-75');
    });
    
    function showFieldError(field, message) {
      field.classList.add('border-red-500');
      
      const errorDiv = document.createElement('p');
      errorDiv.className = 'text-red-600 text-sm mt-1';
      errorDiv.textContent = message;
      errorDiv.id = field.id + '_error';
      
      field.parentNode.appendChild(errorDiv);
    }
    
    function clearFieldError(field) {
      field.classList.remove('border-red-500');
      
      const errorDiv = document.getElementById(field.id + '_error');
      if (errorDiv) {
        errorDiv.remove();
      }
    }
  }); 