#flash-container.fixed.bottom-6.left-6.z-50.flex.flex-col.gap-3.max-w-md.w-full.sm:w-auto
  - flash.each do |key, message|
    - bg_color = case key.to_s
      - when 'notice', 'success' then 'bg-teal-50 border-teal-200 text-teal-800 shadow-teal-100'
      - when 'alert', 'error' then 'bg-red-50 border-red-200 text-red-800 shadow-red-100'
      - else 'bg-blue-50 border-blue-200 text-blue-800 shadow-blue-100'
    
    %div{ class: "flex p-4 rounded-xl border shadow-lg transform transition-all duration-500 ease-in-out #{bg_color}", role: "alert", id: "flash-#{key}", data: { controller: "flash" } }
      %div.flex.items-start.w-full
        - if key.to_s == 'notice' || key.to_s == 'success'
          %i.fas.fa-check-circle.mt-1.mr-3.text-teal-500.flex-shrink-0
        - else
          %i.fas.fa-exclamation-circle.mt-1.mr-3.text-red-500.flex-shrink-0
        
        %div.flex-1.mr-4
          %p.text-sm.font-semibold
            = message
            
        %button.inline-flex.text-gray-400.hover:text-gray-600.focus:outline-none{ type: "button", data: { action: "flash#close" }, "aria-label": "Close" }
          %span.sr-only Close
          %i.fas.fa-times.text-sm
