- content_for :head do
  :css
    /* TOC sidebar */
    .toc-link {
      display: block;
      padding: 0.45rem 0.85rem;
      font-size: 0.82rem;
      color: #4b5563;
      border-left: 3px solid transparent;
      border-radius: 0 4px 4px 0;
      transition: all 0.18s ease;
      line-height: 1.4;
      text-decoration: none;
    }
    .toc-link:hover,
    .toc-link.active {
      color: #3a6363;
      border-left-color: #3a6363;
      background: rgba(58,99,99,0.06);
      font-weight: 600;
    }

    /* Section cards */
    .terms-section {
      scroll-margin-top: 100px;
    }

    /* Section number badge */
    .section-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: #3a6363;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* List items inside sections */
    .terms-body ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .terms-body ul li {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.6rem;
      color: #374151;
      font-size: 0.95rem;
      line-height: 1.65;
    }
    .terms-body ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.6em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #3a6363;
      opacity: 0.6;
    }
    .terms-body ul ul {
      margin-top: 0.5rem;
    }
    .terms-body ul ul li::before {
      background: #9ca3af;
      width: 4px;
      height: 4px;
    }

    /* Signature lines */
    .sig-line {
      border-bottom: 2px solid #d1d5db;
      min-height: 2.5rem;
      margin-top: 0.25rem;
    }

    /* Print */
    @media print {
      .toc-sidebar, .terms-hero, .back-btn { display: none !important; }
      .terms-main { max-width: 100% !important; }
    }

%div.min-h-screen{style: 'background: #f8fafb'}

  / ── Hero Banner ──────────────────────────────────────────
  %section.relative.overflow-hidden{style: 'background: linear-gradient(135deg, #3a6363 0%, #2d4f4f 60%, #1e3535 100%)'}
    / Decorative circles
    %span.absolute.rounded-full.opacity-10{style: 'width:420px;height:420px;background:#fff;top:-160px;right:-120px;'}
    %span.absolute.rounded-full.opacity-10{style: 'width:220px;height:220px;background:#fff;bottom:-80px;left:-60px;'}

    .terms-hero.relative.z-10.max-w-5xl.mx-auto.px-6.py-16.text-center
      .inline-flex.items-center.justify-center.w-16.h-16.rounded-2xl.mb-6{style: 'background: rgba(255,255,255,0.15)'}
        %i.fas.fa-file-contract.text-white.text-2xl
      %h1.text-4xl.md:text-5xl.font-extrabold.text-white.mb-3 Terms &amp; Conditions
      %p.text-lg.mb-5{style: 'color: rgba(255,255,255,0.8)'}
        B2B Partnership Agreement between Wheelsonrent-FZCO and Car Rental Partners
      .inline-flex.items-center.gap-2.px-4.py-2.rounded-full.text-sm{style: 'background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.9)'}
        %i.fas.fa-calendar-alt.text-xs
        %span Last Updated: September 15, 2025

  / ── Layout: TOC + Content ────────────────────────────────
  .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.py-12

    .flex.gap-10.items-start

      / ── Sticky TOC Sidebar ──────────────────────────────
      .toc-sidebar.hidden.lg:block.flex-shrink-0{style: 'width: 220px; position: sticky; top: 80px;'}
        .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.overflow-hidden
          .px-4.py-3.border-b.border-gray-100{style: 'background: #f0f5f5'}
            %p.text-xs.font-bold.uppercase.tracking-widest{style: 'color: #3a6363'} Contents
          %nav#toc-nav.py-2
            %a.toc-link{href: '#section-1'}  1. Partnership Name
            %a.toc-link{href: '#section-2'}  2. Payment Policy
            %a.toc-link{href: '#section-3'}  3. Cancellation
            %a.toc-link{href: '#section-4'}  4. Advertising
            %a.toc-link{href: '#section-5'}  5. Damages & Liability
            %a.toc-link{href: '#section-6'}  6. Fines & Penalties
            %a.toc-link{href: '#section-8'}  8. Termination
            %a.toc-link{href: '#section-9'}  9. Custom Package
            %a.toc-link{href: '#section-10'} 10. Terms
            %a.toc-link{href: '#section-11'} 11. Response Time
            %a.toc-link{href: '#section-12'} 12. Pricing Policy
            %a.toc-link{href: '#section-13'} 13. Client Policy
            %a.toc-link{href: '#section-14'} 14. Maintenance
            %a.toc-link{href: '#signatures'}  Signatures

        / Back to top button
        .mt-4.text-center
          %a.back-btn.inline-flex.items-center.gap-1.text-xs.font-medium.px-3.py-2.rounded-lg.border.transition{href: '#', style: 'color: #3a6363; border-color: #d1d5db;', onmouseover: "this.style.background='#f0f5f5'", onmouseout: "this.style.background='transparent'"}
            %i.fas.fa-arrow-up.text-xs
            Back to top

      / ── Main Content ─────────────────────────────────────
      .terms-main.flex-1.min-w-0

        / Intro card
        .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-6
          .flex.items-start.gap-4
            .flex-shrink-0.w-10.h-10.rounded-xl.flex.items-center.justify-center{style: 'background: #eef4f4'}
              %i.fas.fa-handshake{style: 'color: #3a6363'}
            %div
              %p.text-sm.text-gray-500.mb-1.font-medium B2B Partnership Agreement
              %p.text-gray-700.leading-relaxed.text-sm
                This Partnership Agreement is made as of this ______ day of ________, 20______, by and between Partner(s):
                %strong.text-gray-900 Wheelsonrent-FZCO
                and
                %strong.text-gray-900 Car Rental Company.
                This Agreement shall be governed by and construed in accordance with the laws of the United Arab Emirates.

        / Section 1
        #section-1.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 1
            %h2.text-lg.font-bold.text-gray-900 Partnership Name and Purpose
          .terms-body
            %p.text-gray-700.text-sm.leading-relaxed
              The Partners agree to form a partnership under the name of Contract Agreement between Wheelsonrent-FZCO and ____________. This Agreement shall be governed by and construed in accordance with the laws of the United Arab Emirates. The Agreement has been formed on the terms and conditions set forth below.

        / Section 2
        #section-2.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 2
            %h2.text-lg.font-bold.text-gray-900 Payment Policy
          .terms-body
            %ul
              %li
                %strong.text-gray-800 2.1.
                Monthly charges are applicable at the start of each service month.
              %li
                %strong.text-gray-800 2.2.
                Wheelsonrent-FZCO reserves the right to terminate this Agreement and suspend services if monthly fees are not received at the beginning of each service month.

        / Section 3
        #section-3.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 3
            %h2.text-lg.font-bold.text-gray-900 Cancellation Policy
          .terms-body
            %ul
              %li
                %strong.text-gray-800 3.1.
                The Car Rental Partner reserves the right to cancel the subscription at any time. Monthly payments will cease starting from the subsequent month.
              %li
                %strong.text-gray-800 3.2.
                The Partner shall continue to receive bookings for the current service month. No refunds will be issued for the current month's subscription.

        / Section 4
        #section-4.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 4
            %h2.text-lg.font-bold.text-gray-900 Advertising
          .terms-body
            %ul
              %li
                %strong.text-gray-800 4.1.
                All promotional content provided by the Partner must comply with Wheelsonrent's advertising guidelines and standards.
              %li
                %strong.text-gray-800 4.2.
                Car rental partners agree that Wheelsonrent may show their vehicles on other websites or social media for advertising purposes.

        / Section 5
        #section-5.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 5
            %h2.text-lg.font-bold.text-gray-900 Damages and Liability
          .terms-body
            %ul
              %li
                %strong.text-gray-800 5.1.
                The Partner is fully responsible for any damages to their vehicles during the rental period.
              %li
                %strong.text-gray-800 5.2.
                The Partner must have appropriate insurance coverage for all vehicles listed on the Wheelsonrent platform.

        / Section 6
        #section-6.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 6
            %h2.text-lg.font-bold.text-gray-900 Fines and Penalties
          .terms-body
            %ul
              %li
                %strong.text-gray-800 6.1.
                The Partner shall bear responsibility for any fines or penalties incurred by their vehicles during the rental period.
              %li
                %strong.text-gray-800 6.2.
                The Partner must inform customers of their obligation to cover traffic violations or other penalties incurred during their rental.

        / Section 8
        #section-8.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 8
            %h2.text-lg.font-bold.text-gray-900 Termination Policy
          .terms-body
            %ul
              %li
                %strong.text-gray-800 8.1.
                Either party may terminate this Agreement by providing at least fifteen (15) days' written notice.
              %li
                %strong.text-gray-800 8.2.
                Termination will not affect rentals already booked and confirmed prior to the termination date.

        / Section 9
        #section-9.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 9
            %h2.text-lg.font-bold.text-gray-900 Customize Package
          .terms-body
            %ul
              %li
                %strong.text-gray-800 9.1.
                If a Car Rental Partner would like to receive more than 10 monthly bookings (Economy &amp; Luxury Cars), please contact us to customize your package.

        / Section 10
        #section-10.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 10
            %h2.text-lg.font-bold.text-gray-900 Terms &amp; Conditions
          .terms-body
            %ul
              %li
                %strong.text-gray-800 10.1.
                If customers extend their rental into the next month, it will be treated as a new booking. Long-term rentals (e.g., 6-month or 1-year) will be counted as three (3) separate bookings.
              %li
                %strong.text-gray-800 10.2.
                If a vehicle belongs to two package categories, the higher package shall apply for subscription purposes.
              %li
                %strong.text-gray-800 10.3.
                When a booking is
                %em NOT
                considered a confirmed booking:
                %ul.mt-2
                  %li A booking will not be counted if the customer's IDs are fake or if the customer has excessive fines. However, the car rental partner must clearly provide the reason for rejecting the booking.
              %li
                %strong.text-gray-800 When a booking IS confirmed:
                %ul.mt-2
                  %li If a booking is cancelled due to the vehicle being unavailable and the car rental partner failed to update the vehicle status on the platform, it will be treated as a partner-side cancellation and counted as a confirmed booking.

        / Section 11
        #section-11.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 11
            %h2.text-lg.font-bold.text-gray-900 Response Time Standards
          .terms-body
            %ul
              %li
                %strong.text-gray-800 11.1.
                Car Partners must respond to all customer inquiries within fifteen (15) minutes.
              %li
                %strong.text-gray-800 11.2.
                Failure to do so may result in the booking being reassigned to another Car Rental Partner without notice.

        / Section 12
        #section-12.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 12
            %h2.text-lg.font-bold.text-gray-900 Standardized Pricing Policy
          .terms-body
            %ul
              %li
                %strong.text-gray-800 12.1.
                Car Partners are required to list their vehicles on Wheelsonrent at prices that are equal to, or lower than, the rates shown on their own platforms or any other platform where their cars are advertised. If prices exceed market rates, Wheelsonrent may suggest adjustments to maintain fair value. To ensure equal opportunity, we aim to keep consistent pricing for similar vehicles, so all partners receive a fair share of customer inquiries.

        / Section 13
        #section-13.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 13
            %h2.text-lg.font-bold.text-gray-900 Client Policy and Platform Integrity
          .terms-body
            %ul
              %li
                %strong.text-gray-800 13.1.
                All Wheelsonrent customers are considered official clients of the platform. Car rental partners are strictly prohibited from redirecting or encouraging these customers to book outside the Wheelsonrent system or bypass the platform in any manner.

        / Section 14
        #section-14.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-4
            %span.section-badge 14
            %h2.text-lg.font-bold.text-gray-900 Vehicle Maintenance &amp; Quality Assurance
          .terms-body
            %p.text-gray-700.text-sm.leading-relaxed
              All vehicles must be clean, roadworthy, and properly maintained, free from any undisclosed defects.

        / ── Signatures ───────────────────────────────────
        #signatures.terms-section.bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-10.mb-5
          .flex.items-center.gap-3.mb-6
            .section-badge
              %i.fas.fa-pen-nib.text-xs
            %h2.text-lg.font-bold.text-gray-900 Signatures
          %p.text-sm.text-gray-600.mb-8.leading-relaxed
            By signing below, both parties confirm their agreement to the terms and conditions set forth in this Contract Agreement.

          .grid.grid-cols-1.md:grid-cols-2.gap-10

            / Wheelsonrent block
            %div
              .flex.items-center.gap-2.mb-5
                .w-2.h-5.rounded-sm{style: 'background:#3a6363'}
                %h4.font-bold.text-gray-800 Wheelsonrent-FZCO
              .space-y-5
                %div
                  %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Signature
                  .sig-line
                %div
                  %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Full Name
                  .sig-line
                .grid.grid-cols-2.gap-4
                  %div
                    %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Title
                    .sig-line
                    %p.text-center.text-xs.text-gray-400.mt-1 CEO
                  %div
                    %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Date
                    .sig-line

            / Partner block
            %div
              .flex.items-center.gap-2.mb-5
                .w-2.h-5.rounded-sm{style: 'background:#3a6363'}
                %h4.font-bold.text-gray-800 Car Rental Partner
              .space-y-5
                %div
                  %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Signature
                  .sig-line
                %div
                  %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Full Name
                  .sig-line
                .grid.grid-cols-2.gap-4
                  %div
                    %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Title
                    .sig-line
                  %div
                    %p.text-xs.text-gray-500.mb-1.uppercase.tracking-wide Date
                    .sig-line

        / ── Footer notice ──────────────────────────────
        .rounded-2xl.px-7.py-6.mb-2{style: 'background: linear-gradient(135deg, #3a6363 0%, #2d4f4f 100%)'}
          .flex.items-start.gap-4
            .flex-shrink-0.w-10.h-10.rounded-xl.flex.items-center.justify-center{style: 'background: rgba(255,255,255,0.15)'}
              %i.fas.fa-shield-alt.text-white
            %div
              %p.font-semibold.text-white.mb-1 Agreement Acceptance
              %p.text-sm{style: 'color: rgba(255,255,255,0.85); line-height: 1.65'}
                By accepting this agreement, you confirm your understanding and acceptance of all terms and conditions set forth in this B2B Partnership Agreement with Wheelsonrent-FZCO. This agreement is governed by the laws of the United Arab Emirates.

/ ── Scroll-spy JS ────────────────────────────────────────
:javascript
  (function () {
    var links = document.querySelectorAll('#toc-nav .toc-link');
    var sections = Array.from(links).map(function(l) {
      return document.querySelector(l.getAttribute('href'));
    }).filter(Boolean);

    function onScroll() {
      var scrollY = window.scrollY + 120;
      var current = sections[0];
      sections.forEach(function(s) {
        if (s.offsetTop <= scrollY) current = s;
      });
      links.forEach(function(l) {
        l.classList.toggle('active', l.getAttribute('href') === '#' + current.id);
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

